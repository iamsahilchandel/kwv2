  batchName                 String      @map("batch_name")
  description               String?
  batchType                 BatchType   @map("batch_type")
  venue                     String?
  startDate                 DateTime    @map("start_date")
  endDate                   DateTime?   @map("end_date")
  frequency                 Json
  numberOfClasses           Int?        @map("number_of_classes")
  expertPayPerClass         Decimal?    @map("expert_pay_per_class") @db.Decimal(10, 2)
  basePrice                 Decimal     @map("base_price") @db.Decimal(10, 2)
  allowMidTermJoining       Boolean     @map("allow_mid_term_joining")
  requireExpertConfirmation Boolean     @map("require_expert_confirmation")
  minimumClassesBooking     Int         @default(1) @map("minimum_classes_booking")
  numberOfSeats             Int?        @map("number_of_seats")
  status                    BatchStatus @default(active)
  minimumClassesCutoffDate  DateTime?   @map("minimum_classes_cutoff_date")
  createdBy                 Int?        @map("created_by")
  lastModifiedBy            Int?        @map("last_modified_by")
  createdAt                 DateTime    @default(now()) @map("created_at")
  updatedAt                 DateTime    @updatedAt @map("updated_at")

  expert  Experts  @relation(fields: [expertId], references: [id])
  center  Center   @relation(fields: [centerId], references: [id])
