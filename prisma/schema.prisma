// classDate is DATE (no time component); startTime/endTime are TIME without date.
// createdBy / lastModifiedBy reference experts but are plain scalars to avoid a
// third named relation on top of expertId.
model BatchClasses {
  id             Int         @id @default(autoincrement())
  batchId        Int         @map("batch_id")
  classDate      DateTime    @map("class_date") @db.Date
  startTime      DateTime    @map("start_time") @db.Time(6)
  endTime        DateTime    @map("end_time") @db.Time(6)
  status         ClassStatus @default(scheduled)
  expertId       Int?        @map("expert_id")
  classType      ClassType   @default(regular) @map("class_type")
  createdBy      Int?        @map("created_by")
  lastModifiedBy Int?        @map("last_modified_by")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  batch  Batches  @relation(fields: [batchId], references: [id])
  expert Experts? @relation(fields: [expertId], references: [id])

  history               BatchClassHistory[]
  scheduledAttendance   BatchClassAttendence[] @relation("AttendanceClass")
  rescheduledAttendance BatchClassAttendence[] @relation("AttendanceRescheduledClass")
  classMedia            BatchClassMedia[]

  rescheduleRequests ClassRescheduleRequests[]
  polls              ReschedulePolls[]

  @@map("batch_classes")
}

// expertId / createdBy / lastModifiedBy all reference experts — three named
// @relation pairs are required to avoid Prisma's ambiguous-relation error.
model BatchClassHistory {
  id             Int         @id @default(autoincrement())
  batchClassId   Int         @map("batch_class_id")
  status         ClassStatus
  classDate      DateTime    @map("class_date")
  startTime      DateTime    @map("start_time") @db.Time(6)
  endTime        DateTime    @map("end_time") @db.Time(6)
  expertId       Int?        @map("expert_id")
  createdBy      Int?        @map("created_by")
  lastModifiedBy Int?        @map("last_modified_by")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  batchClass BatchClasses @relation(fields: [batchClassId], references: [id])
  expert     Experts?     @relation("BatchClassHistoryExpert", fields: [expertId], references: [id])
  creator    Experts?     @relation("BatchClassHistoryCreatedBy", fields: [createdBy], references: [id])
  modifier   Experts?     @relation("BatchClassHistoryModifiedBy", fields: [lastModifiedBy], references: [id])

  @@map("batch_class_history")
}

model BatchEnrollments {
