  description    String?
  createdBy      BigInt?       @map("created_by")
  lastModifiedBy BigInt?       @map("last_modified_by")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  centerServices   CenterServices[]
  futureActivities FutureProposedActivities[]
  expertExperties  ExpertExperties[]
  interestServices ExpertInterestServices[]

  learnerInterests LearnersInterest[]

  batches       Batches[]
  batchRequests BatchRequests[]

  @@map("services")
}

