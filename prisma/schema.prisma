// Three self-referential FKs require three named @relation pairs to avoid
// Prisma's "ambiguous relation" error.
model AppAdminStaff {
  id             Int       @id @default(autoincrement())
  firebaseUid    String?   @unique @map("firebase_uid")
  fullName       String    @map("full_name") @db.VarChar(50)
  email          String    @unique
  phoneNumber    String    @unique @map("phone_number") @db.VarChar(15)
  role           AdminRole
  reportsTo      Int?      @map("reports_to")
  createdBy      Int?      @map("created_by")
  lastModifiedBy Int?      @map("last_modified_by")
  isActive       Boolean   @default(false) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Self-referential relations
  manager        AppAdminStaff?  @relation("AdminHierarchy", fields: [reportsTo], references: [id])
  subordinates   AppAdminStaff[] @relation("AdminHierarchy")
  creator        AppAdminStaff?  @relation("AdminCreatedBy", fields: [createdBy], references: [id])
  createdOthers  AppAdminStaff[] @relation("AdminCreatedBy")
  modifier       AppAdminStaff?  @relation("AdminModifiedBy", fields: [lastModifiedBy], references: [id])
  modifiedOthers AppAdminStaff[] @relation("AdminModifiedBy")

  // Back-ref: LearnerProfiles.verifiedBy → AppAdminStaff
  verifiedProfiles LearnerProfiles[] @relation("LearnerProfileVerifiedBy")

  @@map("app_admin_staff")
}

// Two self-referential FKs + back-refs for all models whose createdBy /
// lastModifiedBy / verifiedBy scalars reference center_staff.id.
model CenterStaff {
  id             Int       @id @default(autoincrement())
  firebaseUid    String?   @map("firebase_uid")
  firstName      String    @map("first_name")
  lastName       String?   @map("last_name")
  email          String?
  phoneNumber    String    @unique @map("phone_number")
  address        Json?
  joinedOn       DateTime? @map("joined_on")
  isActive       Boolean   @default(true) @map("is_active")
  createdBy      Int?      @map("created_by")
  lastModifiedBy Int?      @map("last_modified_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Self-referential
  creator       CenterStaff?  @relation("StaffCreatedBy", fields: [createdBy], references: [id])
  createdStaff  CenterStaff[] @relation("StaffCreatedBy")
  modifier      CenterStaff?  @relation("StaffModifiedBy", fields: [lastModifiedBy], references: [id])
  modifiedStaff CenterStaff[] @relation("StaffModifiedBy")

  // Back-refs from Experts
  verifiedExperts Experts[] @relation("ExpertVerifiedBy")
  createdExperts  Experts[] @relation("ExpertCreatedBy")
  modifiedExperts Experts[] @relation("ExpertModifiedBy")

  // Back-refs from Learners
  createdLearners  Learners[] @relation("LearnerCreatedBy")
  modifiedLearners Learners[] @relation("LearnerModifiedBy")

  // Back-refs from LearnerProfiles
  createdProfiles  LearnerProfiles[] @relation("LearnerProfileCreatedBy")
  modifiedProfiles LearnerProfiles[] @relation("LearnerProfileModifiedBy")

  headedCenters      Center[]                  @relation("CenterHead")
  staffMemberships   CenterHasManyStaff[]
  staffVerifications CenterStaffVerification[]

  approvedAccessRequests LearnerCenterAccessRequests[]

  signedAgreements Agreements[]

  @@map("center_staff")
}

// Experts.locationForWork uses PostGIS geometry — all geo queries must use $queryRaw.
// centerId is a plain scalar FK (Center defined in Phase 3).
// verifiedBy / createdBy / lastModifiedBy originally BIGINT in Sequelize but normalized
// to Int? here to match CenterStaff.id (Int PK) and enable proper @relation.
model Experts {
  id                           Int                             @id @default(autoincrement())
  firebaseUid                  String?                         @map("firebase_uid")
  centerId                     Int?                            @map("center_id")
  firstName                    String                          @map("first_name")
  lastName                     String                          @map("last_name")
  email                        String
  phoneNumber                  String                          @unique @map("phone_number")
  dateOfBirth                  DateTime?                       @map("date_of_birth")
  address                      Json?
  locationForWork              Unsupported("geometry(Point)")? @map("location_for_work")
  rangeForWork                 Int?                            @default(5000) @map("range_for_work")
  profilePicture               String?                         @map("profile_picture")
  mediaKey                     String?                         @map("media_key")
  gender                       Gender
  isVerified                   Boolean                         @default(false) @map("is_verified")
  verifiedOn                   DateTime?                       @map("verified_on")
  verifiedBy                   Int?                            @map("verified_by")
  isActive                     Boolean                         @default(false) @map("is_active")
  isPublic                     Boolean                         @default(true) @map("is_public")
  isOpenForWork                Boolean                         @default(false) @map("is_open_for_work")
  preferredWorkingTimeSlots    Json?                           @map("preferred_working_time_slots")
  termsAndConditionsAccepted   Boolean                         @default(false) @map("terms_and_conditions_accepted")
  termsAndConditionsAcceptedOn DateTime?                       @map("terms_and_conditions_accepted_on")
  isFreelancer                 Boolean                         @default(false) @map("is_freelancer")
  referralCode                 String?                         @unique @map("referral_code")
  createdBy                    Int?                            @map("created_by")
  lastModifiedBy               Int?                            @map("last_modified_by")
  createdAt                    DateTime                        @default(now()) @map("created_at")
  updatedAt                    DateTime                        @updatedAt @map("updated_at")

  verifiedByStaff     CenterStaff?           @relation("ExpertVerifiedBy", fields: [verifiedBy], references: [id])
  createdByStaff      CenterStaff?           @relation("ExpertCreatedBy", fields: [createdBy], references: [id])
  lastModifiedByStaff CenterStaff?           @relation("ExpertModifiedBy", fields: [lastModifiedBy], references: [id])
  center              Center?                @relation("ExpertCenter", fields: [centerId], references: [id])
  expertMemberships   CenterHasManyExperts[]

  about           ExpertAbout[]
  media           ExpertMedia[]
  kycDocs         ExpertKycVerification[]
  experties       ExpertExperties[]
  centerInterests ExpertCenterInterest[]

  batches              Batches[]
  taughtClasses        BatchClasses[]
  batchRequests        BatchRequests[]
  classMedia           BatchClassMedia[]
  classHistoryAsExpert BatchClassHistory[] @relation("BatchClassHistoryExpert")
  createdClassHistory  BatchClassHistory[] @relation("BatchClassHistoryCreatedBy")
  modifiedClassHistory BatchClassHistory[] @relation("BatchClassHistoryModifiedBy")

  payments          Payment[]
  coupons           Coupon[]
  couponRedemptions CouponRedemption[]

  signedAgreements Agreements[]

  @@unique([centerId, phoneNumber], name: "experts_center_phone_unique")
  @@map("experts")
}

// phoneNumber is BIGINT in Sequelize (stored as a number, not a formatted string).
// profileId is a plain scalar FK pointing at the learner's "current active" LearnerProfile;
// the full many-to-many relationship is established via learnerHasManyProfiles in Phase 5.
// createdBy / lastModifiedBy normalized to Int? to match CenterStaff.id (Int PK).
model Learners {
  id              Int       @id @default(autoincrement())
  profileId       BigInt?   @map("profile_id")
  firebaseUid     String?   @unique @map("firebase_uid")
  firstName       String    @map("first_name")
  lastName        String?   @map("last_name")
  email           String?   @unique
  phoneNumber     BigInt    @unique @map("phone_number")
  termsAccepted   Boolean   @default(false) @map("terms_accepted")
  termsAcceptedOn DateTime? @map("terms_accepted_on")
  createdBy       Int?      @map("created_by")
  lastModifiedBy  Int?      @map("last_modified_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  createdByStaff      CenterStaff? @relation("LearnerCreatedBy", fields: [createdBy], references: [id])
  lastModifiedByStaff CenterStaff? @relation("LearnerModifiedBy", fields: [lastModifiedBy], references: [id])

  media            LearnerMedia[]
  profileJunctions LearnerHasManyProfiles[]

  couponRedemptions CouponRedemption[]

  signedAgreements Agreements[]

  @@map("learners")
}

// location uses PostGIS geometry — all geo queries must use $queryRaw.
// verifiedBy normalized to Int? to match AppAdminStaff.id (Int PK).
// createdBy / lastModifiedBy normalized to Int? to match CenterStaff.id (Int PK).
model LearnerProfiles {
  id                Int                             @id @default(autoincrement())
  firstName         String?                         @map("first_name")
  lastName          String?                         @map("last_name")
  email             String?
  phoneNumber       String?                         @map("phone_number")
  dateOfBirth       DateTime?                       @map("date_of_birth")
  address           Json?
  gender            Gender?
  profilePicture    String?                         @map("profile_picture")
  profilePictureKey String?                         @map("profile_picture_key")
  relation          String?
  location          Unsupported("geometry(Point)")?
  isActive          Boolean                         @default(false) @map("is_active")
  isVerified        Boolean                         @default(false) @map("is_verified")
  verifiedOn        DateTime?                       @map("verified_on")
  verifiedBy        Int?                            @map("verified_by")
  referralCode      String?                         @unique @map("referral_code")
  createdBy         Int?                            @map("created_by")
  lastModifiedBy    Int?                            @map("last_modified_by")
  createdAt         DateTime                        @default(now()) @map("created_at")
  updatedAt         DateTime                        @updatedAt @map("updated_at")

  verifiedByAdmin     AppAdminStaff? @relation("LearnerProfileVerifiedBy", fields: [verifiedBy], references: [id])
  createdByStaff      CenterStaff?   @relation("LearnerProfileCreatedBy", fields: [createdBy], references: [id])
  lastModifiedByStaff CenterStaff?   @relation("LearnerProfileModifiedBy", fields: [lastModifiedBy], references: [id])

  kycDocs              LearnerProfileKycVerifications[]
  centerMemberships    LearnerProfileHasManyCenters[]
  centerAccessRequests LearnerCenterAccessRequests[]
  interests            LearnersInterest[]
  learnerJunctions     LearnerHasManyProfiles[]

  enrollments BatchEnrollments[]
  attendance  BatchClassAttendence[]
  mediaAccess BatchClassMediaAccess[]

  pollResponses ReschedulePollResponses[]
  trialRequests TrialRequests[]

  payments       Payment[]
  coupons        Coupon[]
  refundRequests EnrollmentRefundRequests[]

  @@map("learner_profiles")
}

// Defined before Center because Center holds a unique FK → center_inquiries.id.
model CenterInquiries {
  id                Int                 @id @default(autoincrement())
  centerName        String              @map("center_name")
  phoneNumber       String              @map("phone_number")
  email             String
  address           Json
  website           String?
  status            CenterInquiryStatus
  assignedBy        Int?                @map("assigned_by")
  assignedTo        Int?                @map("assigned_to")
  servicesAvailable String[]            @map("services_available")
  createdBy         Int?                @map("created_by")
  lastModifiedBy    Int?                @map("last_modified_by")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  registeredCenter Center?
  notes            CenterInquiryNote[]

  @@map("center_inquiries")
}

// geoLocation uses PostGIS geometry(Point,4326) — all geo queries must use $queryRaw.
// reasonForNotVerified / onboardingPaymentRejectionReason are PostgreSQL text arrays.
// centerInquiryId is a unique FK (one-to-one with CenterInquiries).
// centerHeadId normalized to Int? (from BIGINT) to match CenterStaff.id (Int PK).
// All payment/approval audit scalar FKs kept as plain Int? (no @relation).
model Center {
  id                               Int                                   @id @default(autoincrement())
  centerInquiryId                  Int?                                  @unique @map("center_inquiry_id")
  centerName                       String                                @map("center_name")
  centerHeadId                     Int?                                  @map("center_head_id")
  establishedDate                  DateTime?                             @map("established_date")
  numberOfEmployees                Int                                   @map("number_of_employees")
  email                            String
  phoneNumber                      String                                @unique @map("phone_number")
  dailyOperatingHours              Json                                  @map("daily_operating_hours")
  address                          Json
  geoLocation                      Unsupported("geometry(Point, 4326)")? @map("geo_location")
  website                          String?
  centerType                       CenterType?                           @map("center_type")
  operatingEntity                  CenterOperatingEntity?                @map("operating_entity")
  isNotifyByEmail                  Boolean                               @default(false) @map("is_notify_by_email")
  isNotifyByPushAlert              Boolean                               @default(false) @map("is_notify_by_push_alert")
  isNotifyBySms                    Boolean                               @default(false) @map("is_notify_by_sms")
  isNotifyByWhatsapp               Boolean                               @default(false) @map("is_notify_by_whatsapp")
  isActive                         Boolean                               @default(false) @map("is_active")
  approvedBy                       Int?                                  @map("approved_by")
  isVerified                       Boolean                               @default(false) @map("is_verified")
  isPublic                         Boolean                               @default(true) @map("is_public")
  reasonForNotVerified             String[]                              @map("reason_for_not_verified")
  isOnboardingPaymentReceived      Boolean                               @default(false) @map("is_onboarding_payment_received")
  onboardingPaymentVerifiedBy      Int?                                  @map("onboarding_payment_verified_by")
  isOnboardingPaymentVerified      Boolean                               @default(false) @map("is_onboarding_payment_verified")
  onboardingPaymentReceivedOn      DateTime?                             @map("onboarding_payment_received_on")
  onboardingPaymentReceivedBy      Int?                                  @map("onboarding_payment_received_by")
