  createdBy                        Int?                                  @map("created_by")
  lastModifiedBy                   Int?                                  @map("last_modified_by")
  coupon                           String?
  couponAppliedOn                  DateTime?                             @map("coupon_applied_on")
  originalOnboardingAmount         Decimal?                              @map("original_onboarding_amount") @db.Decimal(15, 2)
  subscriptionAmount               Decimal?                              @map("subscription_amount") @db.Decimal(15, 2)
