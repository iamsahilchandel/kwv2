// amenities / services store arrays of IDs (denormalised snapshot of the request).
// centerMedia / centerVerification store arrays of JSONB objects (inline doc snapshots).
// geoLocation uses PostGIS geometry — geo queries must use $queryRaw.
// establishedDate uses @db.Date (DATE without time, Sequelize DATEONLY).
// approvedBy / rejectedBy reference AppAdminStaff; createdBy references CenterStaff — all plain scalars.
model UpdateCenterDetailsRequest {
  id                          Int                                   @id @default(autoincrement())
  centerId                    Int                                   @map("center_id")
  centerName                  String?                               @map("center_name")
  establishedDate             DateTime?                             @map("established_date") @db.Date
  numberOfEmployees           Int?                                  @map("number_of_employees")
  email                       String?
  phoneNumber                 String?                               @map("phone_number")
  dailyOperatingHours         Json?                                 @map("daily_operating_hours")
  address                     Json?
  geoLocation                 Unsupported("geometry(Point, 4326)")? @map("geo_location")
  website                     String?
  centerType                  CenterType?                           @map("center_type")
  operatingEntity             CenterOperatingEntity?                @map("operating_entity")
  isNotifyByEmail             Boolean?                              @map("is_notify_by_email")
  isNotifyByPushAlert         Boolean?                              @map("is_notify_by_push_alert")
  isNotifyBySms               Boolean?                              @map("is_notify_by_sms")
  isNotifyByWhatsapp          Boolean?                              @map("is_notify_by_whatsapp")
  isPublic                    Boolean?                              @default(true) @map("is_public")
  amenities                   Int[]
  services                    Int[]
  centerDescription           String?                               @map("center_description")
  vision                      String?
  centerBankAccountHolderName String?                               @map("center_bank_account_holder_name")
  centerBankAccountNumber     String?                               @map("center_bank_account_number")
  centerBankName              String?                               @map("center_bank_name")
  centerIfscCode              String?                               @map("center_ifsc_code")
  centerBranchAddress         Json?                                 @map("center_branch_address")
  centerMedia                 Json[]                                @map("center_media")
  centerVerification          Json[]                                @map("center_verification")
  status                      UpdateRequestStatus                   @default(PENDING)
  rejectionReason             String?                               @map("rejection_reason")
  approvedOn                  DateTime?                             @map("approved_on")
  rejectedOn                  DateTime?                             @map("rejected_on")
  approvedBy                  Int?                                  @map("approved_by")
  rejectedBy                  Int?                                  @map("rejected_by")
  createdBy                   Int?                                  @map("created_by")
  createdAt                   DateTime                              @default(now()) @map("created_at")
  updatedAt                   DateTime                              @updatedAt @map("updated_at")

  center Center @relation(fields: [centerId], references: [id])

  @@map("update_center_details_request")
}

