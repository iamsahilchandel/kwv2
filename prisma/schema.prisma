  createdBy           Int?             @map("created_by")
  lastModifiedBy      Int?             @map("last_modified_by")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  batch          Batches         @relation(fields: [batchId], references: [id])
  learnerProfile LearnerProfiles @relation(fields: [learnerProfileId], references: [id])

  attendance BatchClassAttendence[]

  payments       Payment[]
  refundRequests EnrollmentRefundRequests[]

  @@map("batch_enrollments")
}

// batchClassId and rescheduledClassId both reference batch_classes — named relations required.
// reschedulingRequestId is a plain scalar FK to class_reschedule_requests (Phase 7).
// attendanceMarkedBy is a plain scalar FK to experts (audit field).
model BatchClassAttendence {
  id                    Int              @id @default(autoincrement())
  learnerProfileId      Int              @map("learner_profile_id")
  batchEnrollmentId     Int              @map("batch_enrollment_id")
  batchClassId          Int              @map("batch_class_id")
  attendanceStatus      AttendanceStatus @default(pending) @map("attendance_status")
  rescheduledClassId    Int?             @map("rescheduled_class_id")
  reschedulingReason    String?          @map("rescheduling_reason")
  reschedulingRequestId Int?             @map("rescheduling_request_id")
  attendanceMarkedBy    Int?             @map("attendance_marked_by")
  attendanceMarkedAt    DateTime?        @map("attendance_marked_at")
  notes                 String?
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  learnerProfile    LearnerProfiles          @relation(fields: [learnerProfileId], references: [id])
  batchEnrollment   BatchEnrollments         @relation(fields: [batchEnrollmentId], references: [id])
  batchClass        BatchClasses             @relation("AttendanceClass", fields: [batchClassId], references: [id])
  rescheduledClass  BatchClasses?            @relation("AttendanceRescheduledClass", fields: [rescheduledClassId], references: [id])
  rescheduleRequest ClassRescheduleRequests? @relation(fields: [reschedulingRequestId], references: [id])

  @@map("batch_class_attendence")
}

model BatchMedia {
  id               Int            @id @default(autoincrement())
  batchId          Int            @map("batch_id")
  mediaType        BatchMediaType @map("media_type")
  mediaUrl         String         @map("media_url")
  mediaKey         String         @map("media_key")
  mediaTitle       String?        @map("media_title")
  mediaDescription String?        @map("media_description")
  contentType      String?        @map("content_type")
  fileSize         BigInt?        @map("file_size")
  isPublic         Boolean        @default(true) @map("is_public")
  displayOrder     Int?           @default(0) @map("display_order")
  createdBy        Int?           @map("created_by")
  lastModifiedBy   Int?           @map("last_modified_by")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  batch Batches @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([mediaType])
  @@index([isPublic])
  @@map("batch_media")
}

model BatchBenefits {
  id                 Int         @id @default(autoincrement())
  batchId            Int         @map("batch_id")
  benefitTitle       String      @map("benefit_title")
  benefitDescription String?     @map("benefit_description")
  benefitType        BenefitType @default(other) @map("benefit_type")
  isActive           Boolean     @default(true) @map("is_active")
  displayOrder       Int?        @default(0) @map("display_order")
  createdBy          Int?        @map("created_by")
  lastModifiedBy     Int?        @map("last_modified_by")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  batch Batches @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([benefitType])
  @@index([isActive])
  @@map("batch_benefits")
}

// batchType is stored as VARCHAR (Sequelize DataTypes.STRING + validate) — use String, not BatchType enum.
// batchId is nullable unique: in PostgreSQL a UNIQUE constraint allows multiple NULLs, so @unique is correct.
// approvedBy is a plain scalar FK to center_staff (audit field).
// Sequelize hooks (beforeCreate / beforeUpdate) move to service layer.
model BatchRequests {
  id                        Int                @id @default(autoincrement())
  expertId                  Int                @map("expert_id")
  centerId                  Int                @map("center_id")
  serviceId                 Int                @map("service_id")
  batchName                 String             @map("batch_name")
  description               String?
  batchType                 String             @map("batch_type")
  venue                     String?
  startDate                 DateTime           @map("start_date")
  endDate                   DateTime?          @map("end_date")
  frequency                 Json
  numberOfClasses           Int?               @map("number_of_classes")
  expertPayPerClass         Decimal            @map("expert_pay_per_class") @db.Decimal(10, 2)
  basePrice                 Decimal            @map("base_price") @db.Decimal(10, 2)
  allowMidTermJoining       Boolean            @default(false) @map("allow_mid_term_joining")
  requireExpertConfirmation Boolean            @default(true) @map("require_expert_confirmation")
  minimumClassesBooking     Int                @default(1) @map("minimum_classes_booking")
  numberOfSeats             Int?               @map("number_of_seats")
  requestStatus             BatchRequestStatus @default(pending) @map("request_status")
  requestMessage            String?            @map("request_message")
  rejectionReason           String?            @map("rejection_reason")
  approvedBy                Int?               @map("approved_by")
  approvedAt                DateTime?          @map("approved_at")
  batchId                   Int?               @unique @map("batch_id")
  notes                     String?
  metadata                  Json?
  benefits                  Json?
  media                     Json?
  createdAt                 DateTime           @default(now()) @map("created_at")
  updatedAt                 DateTime           @updatedAt @map("updated_at")

  expert  Experts  @relation(fields: [expertId], references: [id])
  center  Center   @relation(fields: [centerId], references: [id])
  service Services @relation(fields: [serviceId], references: [id])
  batch   Batches? @relation(fields: [batchId], references: [id])

  @@index([expertId], name: "batch_requests_expert_id_idx")
  @@index([centerId], name: "batch_requests_center_id_idx")
  @@index([requestStatus], name: "batch_requests_status_idx")
  @@index([expertId, centerId], name: "batch_requests_expert_center_idx")
  @@index([expertId, requestStatus], name: "batch_requests_expert_status_idx")
  @@index([centerId, requestStatus], name: "batch_requests_center_status_idx")
  @@index([createdAt], name: "batch_requests_created_at_idx")
  @@index([startDate], name: "batch_requests_start_date_idx")
  @@map("batch_requests")
}

// mediaVisibility = "all" means no access records needed; "specific" requires BatchClassMediaAccess rows.
model BatchClassMedia {
  id              Int                 @id @default(autoincrement())
  batchClassId    Int                 @map("batch_class_id")
  expertId        Int                 @map("expert_id")
  mediaType       BatchClassMediaType @map("media_type")
  mediaUrl        String              @map("media_url")
  mediaKey        String              @map("media_key")
  fileName        String              @map("file_name")
  fileSize        BigInt?             @map("file_size")
  mimeType        String?             @map("mime_type")
  title           String?
  description     String?
  uploadedAt      DateTime            @default(now()) @map("uploaded_at")
  isActive        Boolean             @default(true) @map("is_active")
  metadata        Json?
  mediaVisibility MediaVisibility     @default(all) @map("media_visibility")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  batchClass    BatchClasses            @relation(fields: [batchClassId], references: [id])
  expert        Experts                 @relation(fields: [expertId], references: [id])
  accessRecords BatchClassMediaAccess[]

  @@map("batch_class_media")
}

// grantedBy is a plain scalar BigInt (can reference any user type — expert or admin).
model BatchClassMediaAccess {
  id                Int             @id @default(autoincrement())
  batchClassMediaId Int             @map("batch_class_media_id")
  learnerProfileId  Int             @map("learner_profile_id")
  grantedAt         DateTime        @default(now()) @map("granted_at")
  grantedBy         BigInt?         @map("granted_by")
  accessType        MediaAccessType @default(full) @map("access_type")
  expiresAt         DateTime?       @map("expires_at")
  isActive          Boolean         @default(true) @map("is_active")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  batchClassMedia BatchClassMedia @relation(fields: [batchClassMediaId], references: [id])
  learnerProfile  LearnerProfiles @relation(fields: [learnerProfileId], references: [id])

  @@map("batch_class_media_access")
}

// requesterId is polymorphic — kept as plain scalar BigInt, resolved in service layer.
model ClassRescheduleRequests {
  id               Int                     @id @default(autoincrement())
  centerId         Int                     @map("center_id")
  batchClassId     Int                     @map("batch_class_id")
  requesterType    RequesterType           @map("requester_type")
  requesterId      BigInt                  @map("requester_id")
  reason           String
  status           RescheduleRequestStatus @default(pending)
  proposedSchedule Json?                   @map("proposed_schedule")
  adminNotes       String?                 @map("admin_notes")
  reviewedBy       Int?                    @map("reviewed_by")
  reviewedAt       DateTime?               @map("reviewed_at")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  center     Center       @relation(fields: [centerId], references: [id])
  batchClass BatchClasses @relation(fields: [batchClassId], references: [id])

  attendances BatchClassAttendence[]
  polls       ReschedulePolls[]

  @@index([batchClassId])
  @@index([requesterType, requesterId])
  @@index([status])
  @@map("class_reschedule_requests")
}

model ReschedulePolls {
  id                  Int        @id @default(autoincrement())
  rescheduleRequestId Int?       @map("reschedule_request_id")
  pollStatus          PollStatus @default(active) @map("poll_status")
  closingDate         DateTime   @map("closing_date")
  title               String
  description         String?
  centerId            Int?       @map("center_id")
  batchClassId        Int?       @map("batch_class_id")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  rescheduleRequest ClassRescheduleRequests? @relation(fields: [rescheduleRequestId], references: [id])
  center            Center?                  @relation(fields: [centerId], references: [id])
  batchClass        BatchClasses?            @relation(fields: [batchClassId], references: [id])

  options ReschedulePollOptions[]

  @@map("reschedule_polls")
}

model ReschedulePollOptions {
  id                Int      @id @default(autoincrement())
  pollId            Int      @map("poll_id")
  proposedDate      DateTime @map("proposed_date")
  proposedStartTime DateTime @map("proposed_start_time") @db.Time(6)
  proposedEndTime   DateTime @map("proposed_end_time") @db.Time(6)
  optionOrder       Int      @default(0) @map("option_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  poll      ReschedulePolls           @relation(fields: [pollId], references: [id])
  responses ReschedulePollResponses[]

  @@map("reschedule_poll_options")
}

model ReschedulePollResponses {
  id               Int          @id @default(autoincrement())
  pollOptionId     Int          @map("poll_option_id")
  learnerProfileId Int          @map("learner_profile_id")
  response         PollResponse
  comments         String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  pollOption     ReschedulePollOptions @relation(fields: [pollOptionId], references: [id])
  learnerProfile LearnerProfiles       @relation(fields: [learnerProfileId], references: [id])

  @@unique([pollOptionId, learnerProfileId])
  @@map("reschedule_poll_responses")
}

// notes is a PostgreSQL TEXT ARRAY (DataTypes.ARRAY(DataTypes.TEXT) in Sequelize).
// createdBy / lastModifiedBy also reference learner_profiles but are kept as plain
// scalars — adding @relation for all three would require three named relations.
model TrialRequests {
  id               Int                @id @default(autoincrement())
  learnerProfileId Int                @map("learner_profile_id")
  batchId          Int                @map("batch_id")
  status           TrialRequestStatus @default(pending)
  requestedAt      DateTime           @default(now()) @map("requested_at")
  notes            String[]
  createdBy        Int?               @map("created_by")
  lastModifiedBy   Int?               @map("last_modified_by")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  learnerProfile LearnerProfiles @relation(fields: [learnerProfileId], references: [id])
  batch          Batches         @relation(fields: [batchId], references: [id])

  @@map("trial_requests")
}

model Payment {
  id                      Int               @id @default(autoincrement())
  paymentType             PaymentType       @map("payment_type")
  enrollmentId            Int?              @map("enrollment_id")
  learnerProfileId        Int?              @map("learner_profile_id")
  centerId                Int?              @map("center_id")
  expertId                Int?              @map("expert_id")
  orderId                 String            @unique @map("order_id")
  orderToken              String?           @map("order_token")
  baseAmount              Decimal           @map("base_amount") @db.Decimal(10, 2)
  convenienceFee          Decimal           @default(0.00) @map("convenience_fee") @db.Decimal(10, 2)
  platformFee             Decimal           @default(0.00) @map("platform_fee") @db.Decimal(10, 2)
  discount                Decimal           @default(0.00) @db.Decimal(10, 2)
  commission              Decimal           @default(0.00) @db.Decimal(10, 2)
  totalAmount             Decimal           @map("total_amount") @db.Decimal(10, 2)
  amount                  Decimal           @db.Decimal(10, 2)
  currency                String            @default("INR")
  paymentMethod           String?           @map("payment_method")
  paymentDate             DateTime?         @map("payment_date")
  status                  PaymentStatus     @default(pending)
  transactionId           String?           @map("transaction_id")
  paymentGatewayResponse  Json?             @map("payment_gateway_response")
  receiptUrl              String?           @map("receipt_url")
  refundId                String?           @map("refund_id")
  refundStatus            String?           @map("refund_status")
  refundAmount            Decimal?          @map("refund_amount") @db.Decimal(10, 2)
  refundDate              DateTime?         @map("refund_date")
  subscriptionPeriodStart DateTime?         @map("subscription_period_start")
  subscriptionPeriodEnd   DateTime?         @map("subscription_period_end")
  subscriptionType        SubscriptionType? @map("subscription_type")
  notes                   String?
  metadata                Json?
  invoiceNumber           String?           @unique @map("invoice_number")
  invoiceUrl              String?           @map("invoice_url")
  invoiceKey              String?           @map("invoice_key")
  invoiceGeneratedAt      DateTime?         @map("invoice_generated_at")
  invoiceStatus           InvoiceStatus     @default(pending) @map("invoice_status")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  enrollment     BatchEnrollments? @relation(fields: [enrollmentId], references: [id])
  learnerProfile LearnerProfiles?  @relation(fields: [learnerProfileId], references: [id])
  center         Center?           @relation(fields: [centerId], references: [id])
  expert         Experts?          @relation(fields: [expertId], references: [id])

  transactions      Transaction[]
  couponRedemptions CouponRedemption[]

  @@index([paymentType])
  @@index([status])
  @@index([enrollmentId])
  @@index([learnerProfileId])
  @@index([centerId])
  @@index([expertId])
  @@index([paymentDate])
  @@index([subscriptionPeriodStart, subscriptionPeriodEnd])
  @@map("payment")
}

model Transaction {
  id                      Int               @id @default(autoincrement())
  paymentId               Int               @map("payment_id")
  orderId                 String            @map("order_id")
  orderAmount             Float             @map("order_amount")
  orderCurrency           String            @default("INR") @map("order_currency")
  orderTags               Json?             @map("order_tags")
  cfPaymentId             String            @map("cf_payment_id")
  paymentStatus           TransactionStatus @map("payment_status")
  paymentAmount           Float             @map("payment_amount")
  paymentCurrency         String            @default("INR") @map("payment_currency")
  paymentMessage          String?           @map("payment_message")
  paymentTime             DateTime?         @map("payment_time")
  bankReference           String?           @map("bank_reference")
  authId                  String?           @map("auth_id")
  paymentMethod           Json?             @map("payment_method")
  paymentGroup            PaymentGroup?     @map("payment_group")
  customerName            String?           @map("customer_name")
  customerId              String?           @map("customer_id")
  customerEmail           String?           @map("customer_email")
  customerPhone           String?           @map("customer_phone")
  errorDetails            Json?             @map("error_details")
  gatewayName             String?           @map("gateway_name")
  gatewayOrderId          String?           @map("gateway_order_id")
  gatewayPaymentId        String?           @map("gateway_payment_id")
  gatewayOrderReferenceId String?           @map("gateway_order_reference_id")
  gatewaySettlement       String?           @map("gateway_settlement")
  gatewayStatusCode       String?           @map("gateway_status_code")
  paymentOffers           Json?             @map("payment_offers")
  cfRefundId              String?           @map("cf_refund_id")
  refundId                String?           @map("refund_id")
  refundAmount            Float?            @map("refund_amount")
  refundCurrency          String?           @map("refund_currency")
  refundType              String?           @map("refund_type")
  refundArn               String?           @map("refund_arn")
  refundStatus            String?           @map("refund_status")
  statusDescription       String?           @map("status_description")
  refundCreatedAt         DateTime?         @map("refund_created_at")
  refundProcessedAt       DateTime?         @map("refund_processed_at")
  refundCharge            Float?            @map("refund_charge")
  refundNote              String?           @map("refund_note")
  refundSplits            Json?             @map("refund_splits")
  refundMode              String?           @map("refund_mode")
  refundReason            String?           @map("refund_reason")
  eventTime               DateTime?         @map("event_time")
  eventType               String?           @map("event_type")
  webhookResponse         Json?             @map("webhook_response")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id])

  @@map("transaction")
}

// startDate / endDate are DATEONLY → @db.Date.
// learnerId references learner_profiles (not learners).
// createdBy / lastModifiedBy are plain scalars (admin-side audit fields).
// Hooks (uppercase code, deplete on limit) move to CouponService.
model Coupon {
  id                  Int               @id @default(autoincrement())
  code                String            @unique @db.VarChar(50)
  description         String?
  type                CouponType        @default(percentage)
  value               Decimal           @db.Decimal(10, 2)
  minPurchaseAmount   Decimal?          @map("min_purchase_amount") @db.Decimal(10, 2)
  maxDiscountAmount   Decimal?          @map("max_discount_amount") @db.Decimal(10, 2)
  startDate           DateTime          @map("start_date") @db.Date
  endDate             DateTime          @map("end_date") @db.Date
  usageLimit          Int?              @map("usage_limit")
  usageCount          Int               @default(0) @map("usage_count")
  userUsageLimit      Int?              @map("user_usage_limit")
  status              CouponStatus      @default(active)
  applicableTo        CouponApplication @default(all) @map("applicable_to")
  centerId            Int?              @map("center_id")
  learnerId           Int?              @map("learner_id")
  expertId            Int?              @map("expert_id")
  batchId             Int?              @map("batch_id")
  isFirstPurchaseOnly Boolean           @default(false) @map("is_first_purchase_only")
  createdBy           Int?              @map("created_by")
  lastModifiedBy      Int?              @map("last_modified_by")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  center         Center?          @relation(fields: [centerId], references: [id])
  learnerProfile LearnerProfiles? @relation(fields: [learnerId], references: [id])
  expert         Experts?         @relation(fields: [expertId], references: [id])
  batch          Batches?         @relation(fields: [batchId], references: [id])

  redemptions CouponRedemption[]

  referrals Referral[]

  @@index([code], name: "idx_coupon_code")
  @@index([status], name: "idx_coupon_status")
  @@index([applicableTo], name: "idx_coupon_applicable_to")
  @@index([centerId], name: "idx_coupon_center_id")
  @@index([learnerId], name: "idx_coupon_learner_id")
  @@index([expertId], name: "idx_coupon_expert_id")
  @@index([batchId], name: "idx_coupon_batch_id")
  @@map("coupon")
}

// learnerId references learners (not learner_profiles) — Sequelize model explicit.
model CouponRedemption {
  id             Int          @id @default(autoincrement())
  couponId       Int          @map("coupon_id")
  learnerId      Int?         @map("learner_id")
  centerId       Int?         @map("center_id")
  expertId       Int?         @map("expert_id")
  paymentId      Int?         @map("payment_id")
  discountAmount Decimal      @map("discount_amount") @db.Decimal(10, 2)
  originalAmount Decimal      @map("original_amount") @db.Decimal(10, 2)
  finalAmount    Decimal      @map("final_amount") @db.Decimal(10, 2)
  isFullPayment  Boolean      @default(false) @map("is_full_payment")
  redeemedAt     DateTime     @default(now()) @map("redeemed_at")
  module         CouponModule
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  coupon  Coupon    @relation(fields: [couponId], references: [id])
  learner Learners? @relation(fields: [learnerId], references: [id])
  center  Center?   @relation(fields: [centerId], references: [id])
  expert  Experts?  @relation(fields: [expertId], references: [id])
  payment Payment?  @relation(fields: [paymentId], references: [id])

  @@index([couponId], name: "idx_coupon_redemption_coupon_id")
  @@index([learnerId], name: "idx_coupon_redemption_learner_id")
  @@index([centerId], name: "idx_coupon_redemption_center_id")
  @@index([expertId], name: "idx_coupon_redemption_expert_id")
  @@index([paymentId], name: "idx_coupon_redemption_payment_id")
  @@map("coupon_redemption")
}

// approvedBy / rejectedBy / processedBy all reference center_staff — kept as
// plain scalar Int? to avoid three named relations between this model and CenterStaff.
// status is RefundStatus enum (Sequelize used DataTypes.STRING for fewer migrations).
// afterUpdate hook (cancel enrollment on approval) moves to RefundService.
model EnrollmentRefundRequests {
  id                    Int          @id @default(autoincrement())
  enrollmentId          Int          @map("enrollment_id")
  requestReason         String       @map("request_reason")
  refundAmount          Decimal      @map("refund_amount") @db.Decimal(10, 2)
  status                RefundStatus @default(pending)
  requestedBy           Int          @map("requested_by")
  requestedAt           DateTime     @default(now()) @map("requested_at")
  approvedBy            Int?         @map("approved_by")
  approvedAt            DateTime?    @map("approved_at")
  rejectedBy            Int?         @map("rejected_by")
  rejectedAt            DateTime?    @map("rejected_at")
  rejectionReason       String?      @map("rejection_reason")
  processedBy           Int?         @map("processed_by")
  processedAt           DateTime?    @map("processed_at")
  processedAmount       Decimal?     @map("processed_amount") @db.Decimal(10, 2)
  processNotes          String?      @map("process_notes")
  supportingDocument    String?      @map("supporting_document")
  supportingDocumentKey String?      @map("supporting_document_key")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  enrollment BatchEnrollments @relation(fields: [enrollmentId], references: [id])
  requester  LearnerProfiles  @relation(fields: [requestedBy], references: [id])

  @@map("enrollment_refund_requests")
}

// id is BigInt (BIGSERIAL) matching the Sequelize DataTypes.BIGINT PK.
// userId is BigInt plain scalar; userType is String (DataTypes.STRING in Sequelize).
model Notifications {
  id        BigInt             @id @default(autoincrement())
  userType  String             @map("user_type")
  userId    BigInt             @map("user_id")
  title     String
  body      String
  data      Json?
  status    NotificationStatus @default(pending)
  sentAt    DateTime?          @map("sent_at")
  readAt    DateTime?          @map("read_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  @@index([userType, userId])
  @@index([status])
  @@map("notifications")
}

// userId is plain scalar Int; userType uses FcmUserType enum (v2 normalisation of
// v1 values "appadmin"/"centerstaff" → admin/center).
model FirebaseToken {
  id          Int         @id @default(autoincrement())
  userId      Int         @map("user_id")
  userType    FcmUserType @map("user_type")
  deviceToken String      @map("device_token")
  deviceType  DeviceType? @map("device_type")
  deviceInfo  Json?       @map("device_info")
  isActive    Boolean     @default(true) @map("is_active")
  lastUsedAt  DateTime    @default(now()) @map("last_used_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([userId, userType])
  @@map("firebase_token")
}

// referrerId / refereeId are plain scalar Int (polymorphic — learner, expert, or center).
// couponCode is a non-id FK to coupon.code (@unique field) — Prisma supports this.
model Referral {
  id           Int                @id @default(autoincrement())
  referrerId   Int                @map("referrer_id")
  referrerType ReferralEntityType @map("referrer_type")
  refereeId    Int                @map("referee_id")
  refereeType  ReferralEntityType @map("referee_type")
  referralCode String             @map("referral_code") @db.VarChar(8)
  status       ReferralStatus     @default(pending)
  rewardType   String?            @map("reward_type") @db.VarChar(50)
  rewardValue  Decimal?           @map("reward_value") @db.Decimal(10, 2)
  couponCode   String?            @map("coupon_code") @db.VarChar(50)
  rewardedAt   DateTime?          @map("rewarded_at")
  usedAt       DateTime?          @map("used_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  coupon Coupon? @relation(fields: [couponCode], references: [code])

  @@index([referralCode])
  @@index([referrerType, referrerId])
  @@index([refereeType, refereeId])
  @@index([status])
  @@map("referral")
}

// centerId is required; signedBy* fields are nullable — only one is set per agreement type.
// rejectionReason is a PostgreSQL TEXT ARRAY (DataTypes.ARRAY(DataTypes.TEXT)).
// signedByLearner references learners (not learner_profiles) per the Sequelize model.
model Agreements {
  id                  Int             @id @default(autoincrement())
  agreementType       AgreementType   @map("agreement_type")
  agreementTitle      String?         @map("agreement_title")
  centerId            Int             @map("center_id")
  signedByCenterStaff Int?            @map("signed_by_center_staff")
  signedByExpert      Int?            @map("signed_by_expert")
  signedByLearner     Int?            @map("signed_by_learner")
  documentUrl         String          @map("document_url")
  mediaKey            String?         @map("media_key")
  status              AgreementStatus @default(pending)
  approvedOn          DateTime?       @map("approved_on")
  rejectedOn          DateTime?       @map("rejected_on")
  rejectionReason     String[]        @map("rejection_reason")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  center      Center       @relation(fields: [centerId], references: [id])
  centerStaff CenterStaff? @relation(fields: [signedByCenterStaff], references: [id])
  expert      Experts?     @relation(fields: [signedByExpert], references: [id])
  learner     Learners?    @relation(fields: [signedByLearner], references: [id])

  @@map("agreements")
}

// learnerProfileId column name preserved from Sequelize even though it references
// learners.id — the original model has this naming mismatch.
model LearnerMedia {
  id               Int              @id @default(autoincrement())
  learnerProfileId Int              @map("learner_profile_id")
  mediaType        LearnerMediaType @map("media_type")
  mediaUrl         String           @map("media_url")
  mediaKey         String           @map("media_key")
  createdBy        Int?             @map("created_by")
  lastModifiedBy   Int?             @map("last_modified_by")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  learner Learners @relation(fields: [learnerProfileId], references: [id])

  @@map("learner_media")
}

// timestamps: false — no createdAt / updatedAt columns.
// verifiedBy / createdBy / lastModifiedBy all reference center_staff — plain
// scalars to avoid three named relations to the same table.
model LearnerProfileKycVerifications {
  id               Int                    @id @default(autoincrement())
  learnerProfileId Int                    @map("learner_profile_id")
  documentType     LearnerKycDocumentType @map("document_type")
  documentNumber   String?                @map("document_number")
  documentUrl      String                 @map("document_url")
  mediaKey         String                 @map("media_key")
  isVerified       Boolean                @default(false) @map("is_verified")
  verifiedBy       Int?                   @map("verified_by")
  verificationMode VerificationMode       @default(manual) @map("verification_mode")
  createdBy        Int?                   @map("created_by")
  lastModifiedBy   Int?                   @map("last_modified_by")

  learnerProfile LearnerProfiles @relation(fields: [learnerProfileId], references: [id])

  @@map("learner_profile_kyc_verifications")
}

// id is BigInt (BIGSERIAL) — Sequelize defines it as DataTypes.BIGINT PK.
// timestamps: false — no createdAt / updatedAt columns.
model LearnerHasManyProfiles {
  id               BigInt @id @default(autoincrement())
  learnerId        Int    @map("learner_id")
  learnerProfileId Int    @map("learner_profile_id")

  learner        Learners        @relation(fields: [learnerId], references: [id])
  learnerProfile LearnerProfiles @relation(fields: [learnerProfileId], references: [id])

  @@map("learner_has_many_profiles")
}

// timestamps: false — no createdAt / updatedAt columns.
// createdBy / lastModifiedBy reference center_staff — plain scalars (audit pattern).
model LearnerProfileHasManyCenters {
  id               Int     @id @default(autoincrement())
  learnerProfileId Int     @map("learner_profile_id")
  centerId         Int     @map("center_id")
  isActive         Boolean @default(true) @map("is_active")
  isVerified       Boolean @default(false) @map("is_verified")
  createdBy        Int?    @map("created_by")
  lastModifiedBy   Int?    @map("last_modified_by")

  learnerProfile LearnerProfiles @relation(fields: [learnerProfileId], references: [id])
  center         Center          @relation(fields: [centerId], references: [id])

  @@map("learner_profile_has_many_centers")
}

// approvedBy is a proper @relation to CenterStaff — it records who actioned the request.
// verificationDocuments / metadata are JSONB fields.
model LearnerCenterAccessRequests {
  id                    Int                 @id @default(autoincrement())
  learnerProfileId      Int                 @map("learner_profile_id")
  centerId              Int                 @map("center_id")
  requestStatus         AccessRequestStatus @default(pending) @map("request_status")
  requestMessage        String?             @map("request_message")
  rejectionReason       String?             @map("rejection_reason")
  approvedBy            Int?                @map("approved_by")
  approvedAt            DateTime?           @map("approved_at")
  relationshipType      RelationshipType?   @map("relationship_type")
  verificationDocuments Json?               @map("verification_documents")
  metadata              Json?
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  learnerProfile LearnerProfiles @relation(fields: [learnerProfileId], references: [id])
  center         Center          @relation(fields: [centerId], references: [id])
  approver       CenterStaff?    @relation(fields: [approvedBy], references: [id])

  @@map("learner_center_access_requests")
}

// Explicit many-to-many junction: LearnerProfiles ↔ Services.
// timestamps: true (underscored: true in Sequelize — same effect as @map).
model LearnersInterest {
  id               Int      @id @default(autoincrement())
  learnerProfileId Int?     @map("learner_profile_id")
  serviceId        Int?     @map("service_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  learnerProfile LearnerProfiles? @relation(fields: [learnerProfileId], references: [id])
  service        Services?        @relation(fields: [serviceId], references: [id])

  @@map("learners_interest")
}
