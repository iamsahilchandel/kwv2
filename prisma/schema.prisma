model PlatformSettings {
  id            Int              @id @default(autoincrement())
  category      String           @db.VarChar(50)
  keyName       String           @map("key_name") @db.VarChar(100)
  valueType     SettingValueType @map("value_type")
  stringValue   String?          @map("string_value")
  numberValue   Decimal?         @map("number_value") @db.Decimal(15, 4)
  booleanValue  Boolean?         @map("boolean_value")
  jsonValue     Json?            @map("json_value")
  datetimeValue DateTime?        @map("datetime_value")
  description   String?
  isActive      Boolean          @default(true) @map("is_active")
  isSystem      Boolean          @default(false) @map("is_system")
  sequence      Int              @default(0)
  createdBy     Int?             @map("created_by")
  updatedBy     Int?             @map("updated_by")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@unique([category, keyName], name: "unique_category_key")
  @@index([category], name: "idx_category")
  @@index([isActive], name: "idx_is_active")
  @@map("platform_settings")
}

